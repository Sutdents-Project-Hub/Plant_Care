# Copy to .env for local development only. Do not commit real secrets.
# Rotate any previously exposed keys before production deployment.
DATABASE_URL=postgresql+psycopg://plant_care:plant_care@localhost:5432/plant_care
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

CORS_ALLOW_ORIGINS=*

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

APP_NAME=Plant Care
EMAIL_BACKEND=console

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=Plant Care
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=10

EXPOSE_API_DOCS=false
PUBLIC_RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_REQUESTS=30
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_RATE_LIMIT_PATHS=/api/v1/auth/register,/api/v1/auth/login,/api/v1/auth/refresh,/api/v1/auth/found_psw,/api/v1/ai/generate_tasks,/api/v1/homepage/search_announcements
