default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    ENV["PATH"] = "#{ENV['HOME']}/.rbenv/shims:/opt/homebrew/bin:#{ENV['PATH']}"

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    sh("cd .. && flutter build ipa")

    ipa_candidates = Dir[File.expand_path("../../build/ios/ipa/*.ipa", __dir__)]
    UI.user_error!("找不到 build/ios/ipa 底下的 ipa 檔案") if ipa_candidates.empty?

    ipa_path = ipa_candidates.first
    puts "Using IPA: #{ipa_path}"

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: false
    )
  end
end
